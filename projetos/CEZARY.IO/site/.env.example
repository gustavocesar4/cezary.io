# Copie para .env.local e preencha. Nenhum destes valores deve ser commitado.

# Resend (envio de e-mail do formulário de orçamento) — resend.com
RESEND_API_KEY=
# E-mail que recebe a notificação de cada novo pedido de orçamento
ORCAMENTO_NOTIFICATION_EMAIL=
# Opcional — remetente verificado no Resend. Sem isso, usa o domínio de teste deles.
RESEND_FROM_EMAIL=

# Canal secundário de registro do lead — URL do Apps Script implantado como
# App da Web (Google Sheets). Ver documentacao/configuracao-integracoes.md.
ORCAMENTO_SECOND_CHANNEL_WEBHOOK=

# Fase 6 — Analytics e lançamento (nenhum obrigatório; cada um liga sozinho
# quando preenchido, sem mudança de código). Ver documentacao/arquitetura.md.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
GOOGLE_SITE_VERIFICATION=
