# Copie para .env.local e preencha. Nenhum destes valores deve ser commitado.

# Resend (envio de e-mail do formulário de orçamento) — resend.com
RESEND_API_KEY=
# E-mail que recebe a notificação de cada novo pedido de orçamento
ORCAMENTO_NOTIFICATION_EMAIL=
# Opcional — remetente verificado no Resend. Sem isso, usa o domínio de teste deles.
RESEND_FROM_EMAIL=

# Canal secundário de registro do lead (webhook — Airtable, Google Sheets via
# Apps Script, Zapier/Make, etc.). Ver documentacao/arquitetura.md.
ORCAMENTO_SECOND_CHANNEL_WEBHOOK=
